# 🚀 Agentic-RAG Environment Variables - Ultimate 9.7+ Configuration

# Server Settings
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Database Settings
CHROMA_DB_PATH=data/chroma_db
CACHE_DIR=data/cache

# AI Provider Selection
# Options: openai, gemini, anthropic, local
AI_PROVIDER=gemini

# Gemini AI Settings (Free Model - Recommended)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TEMPERATURE=0.7

# Multiple Gemini API Keys (for load balancing/rate limiting)
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

# OpenAI Settings (Optional)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_API_KEY_2=
OPENAI_API_KEY_3=
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_TEMPERATURE=0.1

# Anthropic Settings (Optional)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-sonnet-20241022
ANTHROPIC_TEMPERATURE=0.1

# Local LLM Settings (Optional)
LOCAL_LLM_URL=http://localhost:11434
LOCAL_LLM_MODEL=mistral
LOCAL_LLM_TEMPERATURE=0.1

# 🚀 Ultimate Performance Settings - 9.7+ Configuration
CHUNK_SIZE=500                    # ⚡ Memory efficient
CHUNK_OVERLAP=50                 # 📝 Optimized overlap
TOP_K_RETRIEVAL=3                 # 🎯 Focused retrieval
SIMILARITY_THRESHOLD=0.7            # 🔍 Quality threshold
MAX_DOCUMENT_SIZE=209715200           # 📄 Max file size (200MB)
MAX_ITERATIONS=1                    # ⚡ Single-pass efficiency
TIMEOUT_SECONDS=30                  # ⏱️ Responsive timeout

# 🧠 Model Configuration - Optimized for 9.7+ Performance
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu
EMBEDDING_NORMALIZE=true

# 🔒 PDF Isolation Settings
ENABLE_PDF_ISOLATION=true
MAX_ACTIVE_PDFS=10
PDF_NAMESPACE_PREFIX=pdf_

# 📋 Structured Extraction Settings
ENABLE_STRUCTURED_EXTRACTION=true
RESUME_SECTIONS=skills,experience,projects,education
TECH_DOC_SECTIONS=overview,architecture,implementation,results

# ⚡ Efficiency Settings
ENABLE_LAZY_LOADING=true
ENABLE_MEMORY_CLEANUP=true
RAM_OPTIMIZATION_LEVEL=high

# 🔄 Query Rewrite Settings
ENABLE_QUERY_REWRITE=true
REWRITE_IMPROVEMENT_THRESHOLD=0.3
MAX_REWRITE_ATTEMPTS=3

# 🎯 Quality Assurance Settings
MIN_GROUNDING_SCORE=0.95
MAX_RESPONSE_LENGTH=500
ENABLE_SEMANTIC_INSIGHTS=true

# 🔍 Logging & Monitoring
LOG_LEVEL=INFO
ENABLE_PERFORMANCE_MONITORING=true
ENABLE_QUERY_ANALYTICS=false

# 🛡️ Security Settings
ENABLE_API_KEY_VALIDATION=true
ENABLE_RATE_LIMITING=true
MAX_REQUESTS_PER_MINUTE=60
OPENAI_BASE_URL=

# Anthropic Settings (Optional)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_API_KEY_2=
ANTHROPIC_API_KEY_3=
ANTHROPIC_MODEL=claude-3-haiku-20240307
ANTHROPIC_TEMPERATURE=0.1

# Local LLM Settings (Ollama - Optional)
LOCAL_LLM_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama2
LOCAL_LLM_TEMPERATURE=0.1

# Embedding Settings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# Document Processing
CHUNK_SIZE=500
CHUNK_OVERLAP=50
MAX_DOCUMENT_SIZE=209715200

# Retrieval Settings
TOP_K_RETRIEVAL=5
SIMILARITY_THRESHOLD=0.7

# Agent Settings
MAX_ITERATIONS=3
TIMEOUT_SECONDS=30

# Security
SECRET_KEY=your-secret-key-change-in-production

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/agentic-rag.log
